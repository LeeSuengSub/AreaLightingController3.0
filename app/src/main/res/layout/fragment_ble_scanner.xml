<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".fragment.BleScannerFragment">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"/>

    <!-- 스캔 상태 표시 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingEnd="10dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:text="비컨 스캔 : "
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/scanState"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:text="Stop"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Scan Start / Stop 버튼 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="4dp">

        <Button
            android:id="@+id/startScanBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="2dp"
            android:backgroundTint="#4169E1"
            android:text="Scan\nStart" />

        <Button
            android:id="@+id/stopScanBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="2dp"
            android:backgroundTint="#4169E1"
            android:text="Scan\nStop" />

        <!-- 리스트 초기화 버튼 -->
        <Button
            android:id="@+id/resetListBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="2dp"
            android:backgroundTint="#4169E1"
            android:text="\n초기화" />
    </LinearLayout>

    <!-- 구분선 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="2dp" />

    <!-- Serial 직접 입력 연결 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="4dp">

        <EditText
            android:id="@+id/editTextSerial"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="3"
            android:hint="serialNumber 직접 입력"
            android:textColorHint="@color/white"
            android:inputType="number"
            android:textColor="@color/white"
            android:maxLines="1"
            android:imeOptions="actionSearch" />

        <Button
            android:id="@+id/connectBtnSerial"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            android:backgroundTint="#4169E1"
            android:text="연결"
            android:textStyle="bold"
            android:textSize="18sp" />
    </LinearLayout>

    <!-- 스캔 결과 리스트 -->
    <ListView
        android:id="@+id/listview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:divider="@null"
        android:dividerHeight="0dp"
        android:textFilterEnabled="true"
        tools:listitem="@layout/scan_list_item" />

</LinearLayout>